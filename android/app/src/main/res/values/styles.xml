<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        AppTheme — dark background, no title bar.
        Used by <application android:theme> and all <activity android:theme>.

        Parent: Theme.AppCompat.NoActionBar
          - Required by AppCompatActivity (all our Activities extend it)
          - Compose setContent() works on both AppCompatActivity and ComponentActivity
          - AppCompatActivity IS a ComponentActivity (superclass chain)

        windowBackground: set to bg_dark so the cold-start white flash is eliminated.
        statusBarColor / navigationBarColor: overridden to transparent per-Activity
          via window.statusBarColor in onCreate() — setting here as fallback.
    -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Prevents brief white frame during Activity transition -->
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!--
        SplashTheme — used only during app cold start.
        Identical appearance to AppTheme but declared separately so it can
        be pointed at by a future SplashScreen API integration without
        touching the main theme.
        Currently unused — MainActivity uses AppTheme directly.
    -->
    <style name="SplashTheme" parent="AppTheme"/>
</resources>
